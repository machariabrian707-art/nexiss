APP_NAME=Nexiss API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexiss
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false

JWT_SECRET_KEY=replace-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

S3_REGION=us-east-1
S3_BUCKET=nexiss-documents
S3_PRESIGN_EXPIRY_SECONDS=900
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

OCR_PROVIDER=mock
OCR_TIMEOUT_SECONDS=60
TEXTRACT_POLL_INTERVAL_SECONDS=2
TEXTRACT_MAX_WAIT_SECONDS=300
LLM_PROVIDER=mock
LLM_MODEL=mock-extractor-v1
LLM_TIMEOUT_SECONDS=60
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REALTIME_PROGRESS_CHANNEL_PREFIX=nexiss:progress

BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OBSERVABILITY_PROVIDER=disabled
SENTRY_DSN=
