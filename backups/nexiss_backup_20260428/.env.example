# =============================================================
# Nexiss — Environment Variables
# Copy this file to .env and fill in your values.
# Variable names must match exactly (they are read by pydantic-settings).
# =============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=Nexiss API
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────
# asyncpg driver used by FastAPI; pg8000 used by Alembic/Celery sync
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexiss

# ── Redis + Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Set to true in local dev to run Celery tasks inline (no worker process needed)
CELERY_TASK_ALWAYS_EAGER=false

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=replace-this-with-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AWS S3 (document storage) ────────────────────────────────
S3_REGION=us-east-1
S3_BUCKET=nexiss-documents
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_PRESIGN_EXPIRY_SECONDS=900

# ── OCR Provider ─────────────────────────────────────────────
# Options: mock | textract
OCR_PROVIDER=mock
OCR_TIMEOUT_SECONDS=60
TEXTRACT_POLL_INTERVAL_SECONDS=2
TEXTRACT_MAX_WAIT_SECONDS=300

# ── LLM Provider (extraction + classification) ───────────────
# Options: mock | openai
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=60
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Realtime (WebSocket progress) ────────────────────────────
REALTIME_PROGRESS_CHANNEL_PREFIX=nexiss:progress

# ── Billing (Stripe) ─────────────────────────────────────────
# Options: disabled | stripe
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Observability ────────────────────────────────────────────
# Options: disabled | sentry
OBSERVABILITY_PROVIDER=disabled
SENTRY_DSN=
